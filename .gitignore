# ── Dependencies ──────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Environment variables (NEVER commit these) ────────────────
.env
.env.local
.env.production
server/.env

# ── SQLite database ───────────────────────────────────────────
server/data.db
server/data.db-shm
server/data.db-wal

# ── Uploaded files (user data — not source code) ──────────────
server/uploads/

# ── Build output ──────────────────────────────────────────────
client/dist/
client/.vite/

# ── OS & editor junk ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log
npm-debug.log*
.vscode/
.idea/

# ── PWA generated files (built at deploy time) ────────────────
client/public/sw.js
client/public/workbox-*.js
